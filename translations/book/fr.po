#: /home/pierre/dev/rust-book-fr/FRENCH/src/ch11-01-writing-tests.md:974
msgid "Running this test produces the following:"
msgstr ""

#: /home/pierre/dev/rust-book-fr/FRENCH/src/ch11-01-writing-tests.md:980
msgid ""
"```console\n"
"{{#include ../listings/ch11-writing-automated-tests/no-listing-06-greeter-"
"with-bug/output.txt}}\n"
"```"
msgstr ""
"```console\n"
"{{#include ../listings/ch11-writing-automated-tests/no-listing-06-greeter-"
"with-bug/output.txt}}\n"
