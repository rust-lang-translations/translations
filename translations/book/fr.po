msgid ""
"<span class=\"caption\">Listing 5-11: Attempting to print a `Rectangle`\n"
"instance</span>"
msgstr ""
"<span class=\"caption\">Encart 5-11 : Tentative d'afficher une instance de\n"
"`Rectangle`</span>"

#: /home/pierre/dev/rust-book-fr/FRENCH/src/ch05-02-example-structs.md:306
msgid "When we compile this code, we get an error with this core message:"
msgstr ""

