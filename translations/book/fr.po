"{{#include ../listings-sources/ch03-common-programming-concepts/no-"
"listing-16-functions/output.txt}}\n"
"```"
msgstr ""
"```console\n"
"{{#include ../listings/ch03-common-programming-concepts/no-listing-16-"
"functions/output.txt}}\n"
